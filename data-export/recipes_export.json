        "amount": "3枚",
        "is_spice": false
      },
      {
        "name": "絹さや",
        "amount": "100g",
        "is_spice": false
      },
      {
        "name": "しょうゆ",
        "amount": "大さじ4",
        "is_spice": true
      },
      {
        "name": "みりん",
        "amount": "大さじ2",
        "is_spice": true
      },
      {
        "name": "砂糖",
        "amount": "大さじ1",
        "is_spice": true
      },
      {
        "name": "顆粒かつおだし",
        "amount": "小さじ2",
        "is_spice": true
      },
      {
