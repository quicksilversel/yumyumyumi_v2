{
  "name": "yumyumyumi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint \"./src/**/*.{ts,tsx}\" && stylelint \"src/**/*.{ts,tsx,js,jsx}\" 2>&1 | grep -v 'Unknown rule' || true && prettier --check --cache --experimental-cli \"./**/*.{ts,tsx,js,jsx,mjs}\"",
    "lint:fix": "eslint --fix \"./src/**/*.{ts,tsx}\" && stylelint \"src/**/*.{ts,tsx,js,jsx}\" --fix && prettier --write --cache --experimental-cli --log-level error \"./**/*.{ts,tsx,js,jsx,mjs}\"",
    "lint:css": "stylelint \"src/**/*.{ts,tsx,js,jsx}\" 2>&1 | grep -v 'Unknown rule' || true",
    "lint:css:fix": "stylelint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "lint:css:raw": "stylelint \"src/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --check --cache --experimental-cli \"./**/*.{ts,tsx,js,jsx,mjs}\"",
    "format:fix": "prettier --write --cache --experimental-cli --log-level error \"./**/*.{ts,tsx,js,jsx,mjs}\"",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "clean:cache": "rm -rf .next/cache",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:storybook": "vitest run --project storybook",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local src/lib/db/seed.ts"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.62.0",
    "ts-case-convert": "^2.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/nextjs-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "^10.4.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "next-router-mock": "^1.0.2",
    "playwright": "^1.55.0",
    "postcss-styled-syntax": "^0.7.1",
    "postcss-syntax": "^0.36.2",
    "prettier": "^3.8.4",
    "storybook": "^10.4.4",
    "stylelint": "^16.24.0",
    "stylelint-config-recess-order": "^7.3.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-no-unsupported-browser-features": "^8.0.4",
    "stylelint-order": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
